# Copy to `.env` in this directory (or set in your shell). Used by `cargo run` / subgraph binaries.
# Point POSTGRES_* at your PostgreSQL instance (cloud or local). Match kabipay-database Liquibase settings.
# You can put the same POSTGRES_* in a sibling `kabipay-database/.env` â€” that file wins when both exist.

# Preferred: single DSN for the ops database (use Neon *-pooler* host in URL to limit compute; include sslmode)
# DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# If the password has special characters, use URL encoding or set POSTGRES_* below instead.

# If DATABASE_URL is unset, these build a DSN (defaults match many local setups)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kabipay_dev
POSTGRES_USER=kabipay
POSTGRES_PASSWORD=changeme

# Managed PostgreSQL (Aiven, Neon, â€¦) usually requires TLS. Set to `require` and match Liquibase `?sslmode=require`.
# Leave unset for local Docker Postgres.
# POSTGRES_SSLMODE=require
#
# Pool size per **process**. Running all subgraphs (scripts/start-subgraphs.ps1) defaults to 1
# so ~19 services fit under a small managed Postgres `max_connections` budget. Single-service
# dev/prod can raise this (default in code is 5 if unset).
# KABIPAY_DB_POOL_MAX=5
# KABIPAY_TENANT_DB_POOL_MAX=3
# KABIPAY_DB_CONNECT_TIMEOUT_SECS=30
# KABIPAY_DB_ACQUIRE_TIMEOUT_SECS=60
# KABIPAY_DB_IDLE_TIMEOUT_SECS=60
#
# If Postgres says: "remaining connection slots are reserved for roles with the SUPERUSER attribute",
# every non-superuser slot is in use. Close other apps (pgAdmin, other subgraphs), keep
# KABIPAY_DB_POOL_MAX=1 per process, or raise `max_connections` / upgrade the DB plan.
#
# --- Free tier / many microservices (auth + many subgraphs) ---
# Each service is a **separate process**; they cannot share one in-memory Postgres connection.
# Put a **pooler** in front of Postgres and aim all *runtime* services at the pool URI so many
# clients multiplex to a small number of real DB sessions:
#   - DigitalOcean: create a "Connection pool" in the control panel â†’ use its host/port in DATABASE_URL.
#   - Neon: use the *-pooler* connection string in DATABASE_URL (saves active compute on free tier).
#   - Aiven: use the "pooler" connection string when offered.
#   - Self-hosted: PgBouncer (session mode for most ORMs; avoid transaction pool for SeaORM unless you know the tradeoffs).
# Keep Liquibase / one-off migrations on the **direct** (non-pool) admin URL when the provider recommends it.
#
# Tight slot budget (uncomment for free tier / many local processes):
# KABIPAY_DB_POOL_MAX=1
# KABIPAY_TENANT_DB_POOL_MAX=1
# KABIPAY_DB_SKIP_PREFLIGHT=1

# JWT (client + operator planes â€” use long random secrets in production)
KABIPAY_OPERATOR_JWT_SECRET=change-me-operator-secret-min-32-chars
KABIPAY_OPERATOR_JWT_EXPIRY_HOURS=8
KABIPAY_CLIENT_JWT_SECRET=change-me-client-secret-min-32-chars
KABIPAY_CLIENT_JWT_EXPIRY_HOURS=1
KABIPAY_CLIENT_REFRESH_EXPIRY_DAYS=30

# Service ports (override if needed)
KABIPAY_AUTH_PORT=4001
KABIPAY_OPERATOR_PORT=4010
KABIPAY_TENANT_PORT=4011
KABIPAY_BILLING_PORT=4012
KABIPAY_EMPLOYEE_PORT=4013
KABIPAY_LEAVE_PORT=4014
KABIPAY_ATTENDANCE_PORT=4015
KABIPAY_PAYROLL_PORT=4016
KABIPAY_TAX_PORT=4017
KABIPAY_BENEFITS_PORT=4018
KABIPAY_EXPENSE_PORT=4019
KABIPAY_RECRUITMENT_PORT=4020
KABIPAY_PERFORMANCE_PORT=4021
KABIPAY_LMS_PORT=4022
KABIPAY_SUCCESSION_PORT=4023
KABIPAY_COMPENSATION_PORT=4024
KABIPAY_ASSETS_PORT=4025
KABIPAY_GRIEVANCE_PORT=4026
KABIPAY_WORKFLOW_PORT=4027
KABIPAY_NOTIFICATION_PORT=4028

# Logging: json | compact
KABIPAY_LOG_FORMAT=json

# Reject unauthenticated `x-tenant-id` for subgraphs (set in production)
# KABIPAY_REQUIRE_AUTH=1

# Employee subgraph: `createEmployee` / `updateEmployee` need JWT with `employee:write` (or HR_ADMIN role) â€” see seed RBAC
# KABIPAY_EMPLOYEE_MUTATION_HEADER_OK=1   # dev only: allow employee writes with header but no JWT (DANGEROUS)
# KABIPAY_INSECURE_ALLOW_EMPTY_RBAC=1     # dev only: allow if JWT has empty roles+permissions (DANGEROUS)

# Shared HS256 secret (client JWT + file download HMAC) â€” match `kabipay-auth` / UI
# KABIPAY_JWT_SECRET=dev-only-change-me-in-prod

# M5 local files: `uploadEmployeeDocument` writes under this root; signed GET `/files/employee-document`
# KABIPAY_LOCAL_FILE_ROOT=data/tenant_files
# Base URL embedded in `employeeDocumentSignedReadUrl` (browser / gateway)
# KABIPAY_EMPLOYEE_PUBLIC_BASE=http://127.0.0.1:4013

# M7 outbox worker (`cargo run -p kabipay-outbox-worker`) â€” same DB as subgraphs
# OUTBOX_POLL_MS=2000
# OUTBOX_MAX_RETRIES=5
# OUTBOX_WEBHOOK_URL=https://example.com/hooks/kabipay-outbox
